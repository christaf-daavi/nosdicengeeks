{{> head}}
<body class="home">

  {{> header}}

  <section class="hero" aria-label="Bienvenida">
    <div class="hero__inner">
      <h1 class="hero__title">{{@website.name}}</h1>
      {{#if @website.description}}
        <p class="hero__description">{{@website.description}}</p>
      {{/if}}
    </div>
  </section>

  <main id="main-content" class="site-main" role="main">
    <div class="container">

      {{#if posts}}
        <section class="posts-section" aria-label="Artículos recientes">
          <h2 class="posts-section__title">Artículos recientes</h2>

          <div class="post-grid">
            {{#each posts}}
              <article class="post-card" aria-label="{{title}}">

                {{#if mainImage}}
                  <a href="{{url}}" class="post-card__image-link" tabindex="-1" aria-hidden="true">
                    <figure class="post-card__figure">
                      <img
                        src="{{mainImage}}"
                        alt="{{#if mainImageAlt}}{{mainImageAlt}}{{else}}Imagen de {{title}}{{/if}}"
                        class="post-card__image"
                        loading="lazy"
                        decoding="async"
                      >
                    </figure>
                  </a>
                {{/if}}

                <div class="post-card__body">

                  <header class="post-card__header">
                    {{#if tags}}
                      <div class="post-card__tags" aria-label="Categorías">
                        {{#each tags}}
                          <a href="{{url}}" class="post-card__tag">{{name}}</a>
                        {{/each}}
                      </div>
                    {{/if}}

                    <h3 class="post-card__title">
                      <a href="{{url}}" class="post-card__title-link">{{title}}</a>
                    </h3>
                  </header>

                  {{#if excerpt}}
                    <p class="post-card__excerpt">{{excerpt}}</p>
                  {{/if}}

                  <footer class="post-card__footer">
                    <time class="post-card__date" datetime="{{createdAt format='YYYY-MM-DD'}}">
                      {{createdAt format="D [de] MMMM, YYYY"}}
                    </time>
                    <a href="{{url}}" class="post-card__read-more" aria-label="Leer más sobre {{title}}">
                      Leer más
                    </a>
                  </footer>

                </div>
              </article>
            {{/each}}
          </div>

          {{#if pagination}}
            <nav class="pagination" role="navigation" aria-label="Paginación">
              {{#if pagination.previousPage}}
                <a href="{{pagination.previousPage}}" class="pagination__link pagination__link--prev" rel="prev">
                  &larr; Más recientes
                </a>
              {{/if}}
              <span class="pagination__info">
                Página {{pagination.currentPage}} de {{pagination.totalPages}}
              </span>
              {{#if pagination.nextPage}}
                <a href="{{pagination.nextPage}}" class="pagination__link pagination__link--next" rel="next">
                  Más antiguos &rarr;
                </a>
              {{/if}}
            </nav>
          {{/if}}

        </section>
      {{else}}
        <p class="no-posts">Aún no hay artículos publicados.</p>
      {{/if}}

    </div>
  </main>

  {{> footer}}

  <script src="{{@website.themeUrl}}/assets/js/main.js" defer></script>
</body>
</html>
