<header class="site-header" role="banner">
  <div class="header-inner">

    <div class="site-branding">
      <a href="{{@website.url}}" class="site-logo-link" aria-label="{{@website.name}} — Inicio">
        {{#if @website.logo}}
          <img src="{{@website.logo}}" alt="{{@website.name}}" class="site-logo">
        {{else}}
          <span class="site-title">{{@website.name}}</span>
        {{/if}}
      </a>
    </div>

    <nav class="main-nav" role="navigation" aria-label="Menú principal">
      <button class="nav-toggle" aria-expanded="false" aria-controls="main-menu" aria-label="Abrir menú">
        <span class="nav-toggle__bar"></span>
        <span class="nav-toggle__bar"></span>
        <span class="nav-toggle__bar"></span>
      </button>

      <ul id="main-menu" class="nav-list" role="list">
        {{#each menus.mainMenu}}
          <li class="nav-item{{#if isActive}} nav-item--active{{/if}}{{#if hasSubmenu}} nav-item--has-children{{/if}}">
            <a href="{{url}}" class="nav-link"{{#if isActive}} aria-current="page"{{/if}}>
              {{label}}
            </a>
            {{#if hasSubmenu}}
              <ul class="nav-submenu" role="list">
                {{#each submenu}}
                  <li class="nav-subitem{{#if isActive}} nav-subitem--active{{/if}}">
                    <a href="{{url}}" class="nav-sublink"{{#if isActive}} aria-current="page"{{/if}}>
                      {{label}}
                    </a>
                  </li>
                {{/each}}
              </ul>
            {{/if}}
          </li>
        {{/each}}
      </ul>
    </nav>

    <div class="header-actions">
      <button id="theme-toggle" class="theme-toggle" aria-label="Cambiar modo oscuro/claro" type="button">
        <span class="theme-toggle__icon theme-toggle__icon--sun" aria-hidden="true">&#9728;</span>
        <span class="theme-toggle__icon theme-toggle__icon--moon" aria-hidden="true">&#9790;</span>
      </button>
    </div>

  </div>
</header>
