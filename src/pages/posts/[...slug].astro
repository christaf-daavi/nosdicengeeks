---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  // Usa el slug del frontmatter si viene definido; si no, cae al slug
  // derivado del nombre de archivo (compatibilidad hacia atrás).
  return posts.map(post => ({
    params: { slug: post.data.slug || post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<PostLayout
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  author={post.data.author}
  tags={post.data.tags}
  image={post.data.image}
  heroLabel={post.data.heroLabel}
  heroTitle={post.data.heroTitle}
  heroCopy={post.data.heroCopy}
  heroLabelColor={post.data.heroLabelColor}
  heroTitleColor={post.data.heroTitleColor}
  heroCopyColor={post.data.heroCopyColor}
>
  <Content />
</PostLayout>
