---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';

const page = await getEntry('pages', 'about');
if (!page) throw new Error('Página "about" no encontrada en src/content/pages/about.md');
const { Content } = await render(page);
---

<BaseLayout
  title={page.data.title}
  description={page.data.description}
  image={page.data.og_image || undefined}
>
  <section class="section">
    <div class="container about-container">

      <header class="about-header">
        <div class="about-prompt">
          <span class="prompt-user">nosdicengeeks</span>
          <span class="prompt-sep">@</span>
          <span class="prompt-host">blog</span>
          <span class="prompt-sep">:~$</span>
          <span class="prompt-cmd"> cat about.md</span>
        </div>
        <h1 class="about-title">{page.data.title}</h1>
      </header>

      <div class="about-body prose">
        <Content />
      </div>

      <div class="about-footer">
        <div class="stat-grid">
          <div class="stat">
            <span class="stat__value">∞</span>
            <span class="stat__label">// tabs abiertos</span>
          </div>
          <div class="stat">
            <span class="stat__value">☕</span>
            <span class="stat__label">// combustible principal</span>
          </div>
          <div class="stat">
            <span class="stat__value">01</span>
            <span class="stat__label">// modo de operación</span>
          </div>
          <div class="stat">
            <span class="stat__value">100%</span>
            <span class="stat__label">// opiniones propias</span>
          </div>
        </div>
      </div>

    </div>
  </section>
</BaseLayout>

<style>
  .about-container {
    max-width: 780px;
  }

  /* Terminal prompt header */
  .about-header {
    margin-bottom: var(--space-8);
  }

  .about-prompt {
    font-family: var(--font-code);
    font-size: var(--text-sm);
    margin-bottom: var(--space-4);
    opacity: 0.7;
  }

  .prompt-user  { color: var(--color-green); }
  .prompt-sep   { color: var(--color-text-faint); }
  .prompt-host  { color: var(--color-blue); }
  .prompt-cmd   { color: var(--color-text-muted); }

  .about-title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
  }

  /* Prose inherited from PostLayout pattern, scoped here */
  .about-body {
    font-size: var(--text-lg);
    line-height: 1.8;
  }

  .about-body :global(h2) {
    font-size: var(--text-2xl);
    margin-top: var(--space-12);
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--color-border-muted);
  }

  .about-body :global(h2::before) {
    content: '## ';
    color: var(--color-green);
    opacity: 0.6;
    font-weight: 300;
  }

  .about-body :global(p) {
    margin-bottom: var(--space-6);
    color: var(--color-text);
  }

  .about-body :global(ul) {
    padding-left: var(--space-6);
    margin-bottom: var(--space-6);
  }

  .about-body :global(li) {
    margin-bottom: var(--space-2);
  }

  .about-body :global(ul li::marker) {
    color: var(--color-green);
  }

  .about-body :global(strong) {
    color: var(--color-text);
    font-weight: 600;
  }

  .about-body :global(em) {
    color: var(--color-text-muted);
  }

  .about-body :global(blockquote) {
    border-left: 3px solid var(--color-green);
    padding: var(--space-3) var(--space-6);
    margin-block: var(--space-6);
    background: rgba(0, 255, 65, 0.04);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .about-body :global(blockquote p) {
    margin-bottom: 0;
  }

  .about-body :global(a) {
    color: var(--color-blue);
    text-underline-offset: 3px;
  }

  .about-body :global(a:hover) {
    color: var(--color-green);
    text-shadow: none;
  }

  /* Stats grid */
  .about-footer {
    margin-top: var(--space-16);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  .stat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: var(--space-4);
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-4);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-align: center;
    transition: border-color var(--transition), box-shadow var(--transition);
  }

  .stat:hover {
    border-color: var(--color-green);
    box-shadow: var(--glow-green);
  }

  .stat__value {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-green);
  }

  .stat__label {
    font-family: var(--font-code);
    font-size: var(--text-xs);
    color: var(--color-text-faint);
  }

  @media (max-width: 768px) {
    .about-body {
      font-size: var(--text-base);
    }
  }
</style>
