---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TagBadge from '../components/TagBadge.astro';
import siteConfig from '../data/site-config.json';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  author: string;
  tags: string[];
  image?: { src: string; alt: string };
}

const { title, description, pubDate, updatedDate, author, tags, image } = Astro.props;

const formattedPubDate = pubDate.toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdatedDate = updatedDate?.toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const gtmId = siteConfig.gtmId || '';
---

<!doctype html>
<html lang="es" data-theme="dark">
  <head>
    <BaseHead title={title} description={description} image={image?.src} />
    {gtmId && (
      <Fragment>
        <!-- Google Tag Manager -->
        <script set:html={`(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
})(window,document,'script','dataLayer','${gtmId}');`} />
        <!-- End Google Tag Manager -->
      </Fragment>
    )}
  </head>
  <body>
    {gtmId && (
      <Fragment>
        <!-- Google Tag Manager (noscript) -->
        <noscript>
          <iframe src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`} height="0" width="0" style="display:none;visibility:hidden"></iframe>
        </noscript>
        <!-- End Google Tag Manager (noscript) -->
      </Fragment>
    )}
    <Header />

    <main id="main-content">
      <article class="post-article">

        <!-- Hero de imagen -->
        {image && (
          <div class="post-hero">
            <img
              src={image.src}
              alt={image.alt}
              class="post-hero__img"
              loading="eager"
              decoding="async"
              width="1200"
              height="400"
            />
          </div>
        )}

        <div class="container post-container">

          <!-- Cabecera del artículo -->
          <header class="post-header">
            {tags.length > 0 && (
              <div class="post-tags">
                {tags.map((tag, i) => (
                  <TagBadge tag={tag} index={i} href={`/tags/${tag}`} />
                ))}
              </div>
            )}

            <h1 class="post-title">{title}</h1>
            <p class="post-description">{description}</p>

            <div class="post-meta">
              <span class="post-meta__author">
                <span class="meta-label">// autor</span>
                <a href="/about">{author}</a>
              </span>

              <span class="post-meta__sep" aria-hidden="true">·</span>

              <time class="post-meta__date" datetime={pubDate.toISOString()}>
                <span class="meta-label">// publicado</span>
                {formattedPubDate}
              </time>

              {updatedDate && (
                <>
                  <span class="post-meta__sep" aria-hidden="true">·</span>
                  <time class="post-meta__date" datetime={updatedDate.toISOString()}>
                    <span class="meta-label">// actualizado</span>
                    {formattedUpdatedDate}
                  </time>
                </>
              )}
            </div>
          </header>

          <!-- Cuerpo del artículo -->
          <div class="post-body prose">
            <slot />
          </div>

          <!-- Footer del artículo -->
          <footer class="post-footer">
            <div class="post-footer__tags">
              <span class="meta-label">// tags</span>
              {tags.map((tag, i) => (
                <TagBadge tag={tag} index={i} href={`/tags/${tag}`} />
              ))}
            </div>
            <a href="/" class="btn btn--outline post-footer__back">← Volver al inicio</a>
          </footer>

        </div>
      </article>
    </main>

    <Footer />
  </body>
</html>

<style>
  /* ── Post layout ────────────────────────────────────────── */
  .post-hero {
    width: 100%;
    height: 400px;
    overflow: hidden;
    border-radius: var(--radius-md);
    margin-bottom: var(--space-6);
  }

  .post-hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .post-container {
    max-width: 780px;
    padding-bottom: 3rem;
  }

  .post-header {
    padding-block: var(--space-12) var(--space-8);
    border-bottom: 1px solid var(--color-border-muted);
    margin-bottom: var(--space-8);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .post-tags :global(.tag) {
    text-decoration: none;
  }

  .post-footer__tags :global(.tag) {
    text-decoration: none;
  }

  .post-title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    line-height: 1.2;
    margin-bottom: var(--space-4);
    color: var(--color-text);
  }

  /* Override global h1::before prompt — this title stands alone */
  .post-title::before {
    content: none;
  }

  .post-description {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: var(--space-6);
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2) var(--space-4);
    font-family: var(--font-code);
    font-size: var(--text-xs);
    color: var(--color-text);
    opacity: 0.8;
  }

  .meta-label {
    color: var(--color-green);
    opacity: 0.7;
    margin-right: var(--space-1);
  }

  .post-meta a {
    color: var(--color-text);
    opacity: 0.85;
  }

  .post-meta a:hover {
    opacity: 1;
    text-shadow: none;
  }

  .post-meta__sep {
    opacity: 0.4;
  }

  /* ── Prose — article body typography ────────────────────── */
  .prose {
    font-size: var(--text-lg);
    line-height: 1.8;
    color: var(--color-text);
  }

  .prose :global(h2),
  .prose :global(h3),
  .prose :global(h4) {
    margin-top: var(--space-12);
    margin-bottom: var(--space-4);
    color: var(--color-text);
  }

  .prose :global(h2) {
    font-size: var(--text-2xl);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--color-border-muted);
  }

  .prose :global(h2::before) {
    content: '## ';
    color: var(--color-green);
    font-weight: 300;
    opacity: 0.6;
  }

  .prose :global(h3::before) {
    content: '### ';
    color: var(--color-blue);
    font-weight: 300;
    opacity: 0.6;
  }

  .prose :global(h4::before) {
    content: none;
  }

  .prose :global(p) {
    margin-bottom: var(--space-6);
  }

  .prose :global(a) {
    color: var(--color-blue);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(4, 150, 255, 0.4);
    transition: opacity var(--transition);
  }

  .prose :global(a:hover) {
    opacity: 0.8;
    text-shadow: none;
  }

  :global([data-theme="light"]) .prose :global(a) {
    color: var(--color-dark-blue);
    text-decoration-color: rgba(0, 107, 166, 0.4);
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: var(--space-6);
    margin-bottom: var(--space-6);
  }

  .prose :global(li) {
    margin-bottom: var(--space-2);
  }

  .prose :global(ul li::marker) {
    color: var(--color-green);
  }

  .prose :global(ol li::marker) {
    color: var(--color-blue);
    font-family: var(--font-code);
    font-size: var(--text-sm);
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-green);
    padding: var(--space-3) var(--space-6);
    margin-block: var(--space-6);
    background: rgba(0, 255, 65, 0.04);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .prose :global(blockquote p) {
    margin-bottom: 0;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-block: var(--space-6);
    font-size: var(--text-sm);
  }

  .prose :global(th) {
    background: var(--color-bg-elevated);
    color: var(--color-green);
    font-family: var(--font-code);
    font-weight: 500;
    padding: var(--space-3) var(--space-4);
    text-align: left;
    border: 1px solid var(--color-border);
  }

  .prose :global(td) {
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--color-border-muted);
  }

  .prose :global(tr:nth-child(even) td) {
    background: rgba(22, 27, 34, 0.5);
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin-block: var(--space-12);
  }

  .prose :global(img) {
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    margin-block: var(--space-6);
  }

  .prose :global(strong) {
    color: var(--color-text);
    font-weight: 600;
  }

  .prose :global(em) {
    color: var(--color-text-muted);
  }

  /* ── Post footer ────────────────────────────────────────── */
  .post-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-top: var(--space-12);
    margin-bottom: 4rem;
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  .post-footer__tags {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-code);
    font-size: var(--text-xs);
  }

  .post-footer__tags .tag {
    text-decoration: none;
  }

  @media (max-width: 768px) {
    .post-hero {
      height: 220px;
    }

    .post-header {
      padding-block: var(--space-8) var(--space-6);
    }

    .prose {
      font-size: var(--text-base);
    }

    .post-footer {
      flex-direction: column;
      align-items: flex-start;
      margin-bottom: 2.5rem;
    }
  }
</style>
