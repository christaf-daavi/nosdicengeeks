---
import TagBadge from './TagBadge.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  slug: string;
  image?: { src: string; alt: string };
}

const { title, description, pubDate, tags, slug, image } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const isoDate = pubDate.toISOString();
---

<article class="post-card">
  <a href={`/posts/${slug}`} class="post-card__link" aria-label={`Leer: ${title}`}>

    {image && (
      <div class="post-card__image-wrapper">
        <img
          src={image.src}
          alt={image.alt}
          class="post-card__image"
          loading="lazy"
          decoding="async"
          width="800"
          height="450"
          sizes="(max-width: 480px) 100vw, (max-width: 1024px) 50vw, 33vw"
        />
      </div>
    )}

    <div class="post-card__body">
      {tags.length > 0 && (
        <div class="post-card__tags" aria-label="Etiquetas">
          {tags.slice(0, 4).map((tag, i) => (
            <TagBadge tag={tag} index={i} />
          ))}
        </div>
      )}

      <h3 class="post-card__title">{title}</h3>

      <p class="post-card__excerpt">{description}</p>

      <div class="post-card__meta">
        <time class="post-card__date" datetime={isoDate}>Publicado el {formattedDate}</time>
        <span class="post-card__read-more" aria-hidden="true">leer →</span>
      </div>
    </div>

  </a>
</article>

<style>
  /* Make the entire card a clickable surface */
  .post-card__link {
    display: flex;
    flex-direction: column;
    height: 100%;
    color: inherit;
    text-decoration: none;
  }

  /* Override global a:hover glow — card handles its own hover */
  .post-card__link:hover {
    text-shadow: none;
    color: inherit;
  }

  .post-card__read-more {
    font-family: var(--font-code);
    font-size: var(--text-sm);
    font-weight: 600;
    color: #ffffff;
    background: var(--color-primary);
    padding: 6px 16px;
    border-radius: 4px;
    white-space: nowrap;
    transition: background var(--transition);
  }

  .post-card:hover .post-card__read-more {
    background: #006ba6;
  }

  /* Ensure h3 inside card never shows the ::before prompt */
  .post-card__title::before {
    content: none !important;
  }
</style>
