---
const navLinks = [
  { href: '/',       label: 'Inicio' },
  { href: '/blog',   label: 'Blog'   },
  { href: '/tags',   label: 'Tags'   },
  { href: '/about',  label: 'About'  },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header" id="site-header">
  <div class="container">
    <a href="/" class="site-logo" aria-label="NosDicenGeeks — inicio">
      <span class="logo-bracket">[</span>Nos<span>Dicen</span>Geeks<span class="logo-bracket">]</span>
    </a>

    <nav aria-label="Navegación principal">
      <ul class="site-nav">
        {navLinks.map(({ href, label }) => (
          <li>
            <a
              href={href}
              aria-current={currentPath === href || (href !== '/' && currentPath.startsWith(href)) ? 'page' : undefined}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <button
      id="theme-toggle"
      class="theme-toggle"
      aria-label="Cambiar tema"
      title="Cambiar tema claro/oscuro"
    >
      <!-- Sun icon (visible in dark mode) -->
      <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="4"/>
        <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
      </svg>
      <!-- Moon icon (visible in light mode) -->
      <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
      </svg>
    </button>
  </div>
</header>

<script>
  const header = document.getElementById('site-header')!;
  const toggleBtn = document.getElementById('theme-toggle')!;
  const root = document.documentElement;

  // ── Glassmorphism on scroll ──────────────────────────────────
  const onScroll = () => {
    header.classList.toggle('scrolled', window.scrollY > 10);
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // ── Theme toggle ─────────────────────────────────────────────
  const STORAGE_KEY = 'ndg-theme';

  const savedTheme = localStorage.getItem(STORAGE_KEY);
  const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
  const isDark = savedTheme ? savedTheme === 'dark' : prefersDark;

  const applyTheme = (dark: boolean) => {
    root.setAttribute('data-theme', dark ? 'dark' : 'light');
    localStorage.setItem(STORAGE_KEY, dark ? 'dark' : 'light');
  };

  applyTheme(isDark);

  toggleBtn.addEventListener('click', () => {
    applyTheme(root.getAttribute('data-theme') !== 'dark');
  });
</script>

<style>
  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: color var(--transition), border-color var(--transition), box-shadow var(--transition);
    flex-shrink: 0;
  }

  .theme-toggle:hover {
    color: var(--color-green);
    border-color: var(--color-green);
    box-shadow: var(--glow-green);
  }

  /* Dark mode: show sun, hide moon */
  :root[data-theme="dark"] .icon-moon,
  :root:not([data-theme="light"]) .icon-moon {
    display: none;
  }

  /* Light mode: show moon, hide sun */
  :root[data-theme="light"] .icon-sun {
    display: none;
  }

  .logo-bracket {
    color: var(--color-green);
    font-weight: 300;
  }

  /* Mobile nav */
  @media (max-width: 600px) {
    .site-nav {
      display: none;
    }
  }
</style>
