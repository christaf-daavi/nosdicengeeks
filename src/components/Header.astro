---
const navLinks = [
  { href: '/',       label: 'Inicio'    },
  { href: '/tags',   label: 'Etiquetas' },
  { href: '/about',  label: 'Nosotros'  },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header" id="site-header">
  <div class="container">
    <a href="/" class="site-logo" aria-label="NosDicenGeeks — inicio">
      <img src="/images/logo.svg" alt="NosDicenGeeks" class="logo-img" width="72" height="72" />
    </a>

    <nav aria-label="Navegación principal">
      <ul class="site-nav">
        {navLinks.map(({ href, label }) => (
          <li>
            <a
              href={href}
              aria-current={currentPath === href || (href !== '/' && currentPath.startsWith(href)) ? 'page' : undefined}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<script>
  const header = document.getElementById('site-header')!;

  // ── Glassmorphism on scroll ──────────────────────────────────
  const onScroll = () => {
    header.classList.toggle('scrolled', window.scrollY > 10);
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>

<style>
  .logo-img {
    height: 72px;
    width: auto;
    display: block;
    background: transparent;
  }

  @media (max-width: 768px) {
    .logo-img {
      height: 64px;
    }

    .site-nav {
      display: none;
    }
  }
</style>
